# Data files — too large / sensitive for version control
data/raw/*
data/data_experiments/*
data/corpora/*

# === JSON policy ===
# Ignore ALL json by default; only the raw model-generated answers (produced on the
# GPU box and synced PC<->box via git) are tracked. Everything else (annotations,
# samples, classification, etc.) is PC-side and regenerable.
*.json
!outputs/answers/short_answers/*.json
!outputs/answers/explicit/*.json
!outputs/answers/sample1500/*.json

# Derived / PC-side spreadsheets + plots (regenerable; not synced)
outputs/analysis/
outputs/answers/samples/*.xlsx

# Logs
logs/

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# claude md files
CLAUDE.md
WORK_LOG.md

# PDF
*.pdf